# FlowClone Windows — .env Configuration
# Copy this file to .env and fill in your keys

# ── Required ──────────────────────────────────────────────────────────────────
# Get your key from https://console.groq.com
GROQ_API_KEY=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

# ── Speech-to-Text Models ──────────────────────────────────────────────────────
# Fast mode (lower latency, great accuracy)
GROQ_SPEECH_MODEL_FAST=whisper-large-v3-turbo

# Accurate mode (highest accuracy, slightly slower)
GROQ_SPEECH_MODEL_ACCURATE=whisper-large-v3

# ── AI Cleanup / Editor Model ─────────────────────────────────────────────────
# Used for filler-word removal, grammar fixing, style rewriting, voice commands
GROQ_EDITOR_MODEL=llama-3.3-70b-versatile
